TZ=Asia/Shanghai

BACKEND_PORT=8080

DB_HOST=10.10.10.11
DB_PORT=3306
DB_NAME=gameeval
DB_USER=gameeval
DB_PASSWORD=change_me_db_password

REDIS_HOST=10.10.10.12
REDIS_PORT=6379
REDIS_PASSWORD=change_me_redis_password
REDIS_DATABASE=0

# JWT / Auth
JWT_SECRET=change-me-to-a-long-random-secret
JWT_ISSUER=gameeval
AUTH_REFRESH_COOKIE_NAME=refreshToken
AUTH_REFRESH_COOKIE_PATH=/api/v1/auth/refresh
AUTH_REFRESH_COOKIE_HTTP_ONLY=true
AUTH_REFRESH_COOKIE_SECURE=true
AUTH_REFRESH_COOKIE_SAME_SITE=None
AUTH_REFRESH_COOKIE_MAX_AGE_SECONDS=604800

# Cache scheduler controls
APP_CACHE_SCHEDULER_ENABLED=true
APP_CACHE_RECONCILE_ENABLED=true
APP_CACHE_RECONCILE_FIXED_DELAY_MS=300000
APP_CACHE_RECONCILE_INITIAL_DELAY_MS=60000
APP_CACHE_WARMUP_ENABLED=true
APP_CACHE_WARMUP_FIXED_DELAY_MS=900000
APP_CACHE_WARMUP_INITIAL_DELAY_MS=120000

APP_ADMIN_INIT_ENABLED=true
APP_ADMIN_INIT_USERNAME=superadmin
APP_ADMIN_INIT_PASSWORD=
APP_ADMIN_INIT_PASSWORD_HASH=
APP_ADMIN_INIT_NAME=System Admin
APP_ADMIN_INIT_ROLE=super_admin
APP_ADMIN_INIT_IS_ENABLED=true
