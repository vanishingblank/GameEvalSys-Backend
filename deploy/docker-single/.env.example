
#没有启用的配置项可以留空或注释

# Time zone
TZ=Asia/Shanghai

# Backend
BACKEND_PORT=8080

# MariaDB
DB_NAME=gameeval
DB_USER=gameeval
DB_PASSWORD=change_me_db_password
DB_ROOT_PASSWORD=change_me_root_password

# Redis
REDIS_PASSWORD=change_me_redis_password
REDIS_DATABASE=0
APP_REDIS_USER=gameeval
APP_REDIS_USER_PASSWORD=

# First deploy admin account
APP_ADMIN_INIT_ENABLED=true
APP_ADMIN_INIT_USERNAME=superadmin

#选择一种初始管理员密码在数据库中的形式（明文/哈希加密方式）
# APP_ADMIN_INIT_PASSWORD=
# 初始哈希密码为admin123
APP_ADMIN_INIT_PASSWORD_HASH=$2a$10$8ylRCdMq/gAne3llbrVn0.dsHYZDotaEK2i6RLpRPMDegYGPZhJKm
APP_ADMIN_INIT_NAME=System Admin
APP_ADMIN_INIT_ROLE=super_admin
APP_ADMIN_INIT_IS_ENABLED=true

# 启用定时任务调度器，默认为true，如果不需要定时任务功能可以设置为false以节省资源
APP_CACHE_SCHEDULER_ENABLED=true
APP_CACHE_RECONCILE_ENABLED=true
APP_CACHE_RECONCILE_FIXED_DELAY_MS=300000
APP_CACHE_RECONCILE_INITIAL_DELAY_MS=60000
APP_CACHE_WARMUP_ENABLED=true
APP_CACHE_WARMUP_FIXED_DELAY_MS=600000
APP_CACHE_WARMUP_INITIAL_DELAY_MS=90000

# CORS (comma-separated). Use * to allow all origins (not recommended in production).
APP_CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost
